{
  "info": {
    "name": "Finance Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "wa_number",
      "value": "628123456789",
      "type": "string"
    },
    {
      "key": "email",
      "value": "user@example.com",
      "type": "string"
    },
    {
      "key": "code",
      "value": "123456",
      "type": "string"
    },
    {
      "key": "trx_id",
      "value": "REPLACE_WITH_REAL_TRX_ID",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"waNumber\": \"{{wa_number}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": ["{{base_url}}"],
              "path": ["register"]
            }
          }
        },
        {
          "name": "Verify",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"waNumber\": \"{{wa_number}}\",\n  \"code\": \"{{code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/verify",
              "host": ["{{base_url}}"],
              "path": ["verify"]
            }
          }
        },
        {
          "name": "Process - Send Email",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from\": \"{{wa_number}}\",\n  \"body\": \"{{email}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/process",
              "host": ["{{base_url}}"],
              "path": ["process"]
            }
          }
        },
        {
          "name": "Process - Verify Code",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from\": \"{{wa_number}}\",\n  \"body\": \"{{email}} verify-{{code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/process",
              "host": ["{{base_url}}"],
              "path": ["process"]
            }
          }
        }
      ]
    },
