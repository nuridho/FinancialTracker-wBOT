# URL of the finance-service HTTP API
FINANCE_SERVICE_URL=http://localhost:3001

# WhatsApp session name (used as folder name for auth state)
SESSION_NAME=wa-finance-bot

# ================================
# INTERNAL AUTH (messaging ↔ finance)
# --------------------------------
# Secret bersama supaya finance-service tahu request ini datang dari messaging-service.
# BUKAN dari layanan pihak ketiga — kamu generate sendiri, nilai bebas & acak.
#
# CARA GENERATE (jalankan di terminal, pilih salah satu):
#   Node.js  :  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   OpenSSL  :  openssl rand -hex 32
#
# PENTING: nilai di sini WAJIB sama persis dengan INTERNAL_API_KEY di finance-service/.env.
#   Beda / kosong salah satu → finance-service balas 401 dan pesan WA tidak terproses.
# Kosongkan untuk dev; isi sebelum deploy publik.
# ================================
INTERNAL_API_KEY=
