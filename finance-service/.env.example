# ================================
# SERVER
# ================================
PORT=3001

# ================================
# SUPABASE
# ================================
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_service_role_key

# ================================
# OPENROUTER
# ================================
OPENROUTER_API_KEY=your_openrouter_api_key

# ================================
# BUSINESS CONFIG
# ================================
PAYDAY_DATE=28
CONFIDENCE_THRESHOLD=70

# ================================
# AUTH — Resend API
# ================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# ================================
# TESTING (opsional)
# Isi untuk bypass auth saat npm test di testing-service.
# TEST_WA_NUMBER harus sama dengan `from` di runner.js ("test-runner").
# TEST_USER_ID = UUID user test di Supabase (lihat tabel users).
# ================================
TEST_WA_NUMBER=test-runner
TEST_USER_ID=your_test_user_uuid

