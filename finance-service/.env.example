# ================================
# SERVER
# ================================
PORT=3001

# ================================
# SUPABASE
# ================================
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_service_role_key

# ================================
# OPENROUTER
# ================================
OPENROUTER_API_KEY=your_openrouter_api_key

# ================================
# BUSINESS CONFIG
# ================================
PAYDAY_DATE=28
CONFIDENCE_THRESHOLD=70

# ================================
# INTERNAL AUTH (messaging ↔ finance)
# --------------------------------
# APA INI: secret bersama (shared secret) untuk memastikan hanya messaging-service
#   yang boleh memanggil /process di finance-service. Tanpa ini, siapa pun yang tahu
#   URL bisa POST /process dengan `from` nomor WA orang lain.
#
# DAPAT DARIMANA: BUKAN dari layanan pihak ketiga (bukan Supabase/OpenRouter/Resend).
#   Kamu generate SENDIRI — nilai bebas, asal string acak yang panjang & sulit ditebak.
#
# CARA GENERATE (pilih salah satu, jalankan di terminal):
#   Node.js  :  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   OpenSSL  :  openssl rand -hex 32
#   PowerShell: [Convert]::ToHexString((1..32|%{Get-Random -Max 256}))
#   → hasilnya string 64-karakter hex, contoh: 9f2c... (copy ke bawah)
#
# CARA PAKAI:
#   1. Generate SATU key.
#   2. Tempel nilai yang SAMA di sini DAN di messaging-service/.env (INTERNAL_API_KEY).
#   3. Kalau nilai beda / salah satu kosong → finance-service tolak dengan 401.
#
# Kosongkan (default) untuk dev/test → guard nonaktif, tidak perlu header.
# Isi sebelum deploy publik. /health selalu terbuka meski guard aktif.
# ================================
INTERNAL_API_KEY=

# ================================
# AUTH — Resend API
# ================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# ================================
# TESTING (opsional)
# Isi untuk bypass auth saat npm test di testing-service.
# TEST_WA_NUMBER harus sama dengan `from` di runner.js ("test-runner").
# TEST_USER_ID = UUID user test di Supabase (lihat tabel users).
# ================================
TEST_WA_NUMBER=test-runner
TEST_USER_ID=your_test_user_uuid

